    <Group name="daily">
        <Attribute name="Description" type="String">
            <Value>gridded daily averages</Value>
        </Attribute>
        <Group name="day20">
            <Float64 name="delta_time_end">
                <Dim size="1"/>
                <Attribute name="long_name" type="String">
                    <Value>Elapsed GPS seconds</Value>
                </Attribute>
                <Attribute name="standard_name" type="String">
                    <Value>time</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>seconds since 2018-01-01</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>Derived via Time Tagging</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>modelResult</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Center time of the last reference surface used in this gridded composite in seconds since the ATLAS SDP GPS Epoch.  The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (1980-01-06T00:00:00.000000Z UTC) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed.</Value>
                </Attribute>
            </Float64>
            <Float32 name="mean_ssha">
                <Dim name="/grid_y"/>
                <Dim name="/grid_x"/>
                <Attribute name="_FillValue" type="Float32">
                    <Value>3.402823466e+38</Value>
                </Attribute>
                <Attribute name="long_name" type="String">
                    <Value>Daily mean sea surface height anomalies</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>meters</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>Sea Ice ATBD</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>modelResult</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Daily mean sea surface height anomalies (SSHA) for each daily grid cell. Sea surface height anomalies expressed relative to the mean sea surface (other geophysical corrections also applied, as indicated in the ATBD) using the reference surface heights.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>../../grid_x ../../grid_y</Value>
                </Attribute>
                <Attribute name="grid_mapping" type="String">
                    <Value>../../crs: ../../grid_x ../../crs: ../../grid_y</Value>
                </Attribute>
                <Map name="/grid_x"/>
                <Map name="/grid_y"/>
            </Float32>
            <Int32 name="n_refsurfs">
                <Dim name="/grid_y"/>
                <Dim name="/grid_x"/>
                <Attribute name="_FillValue" type="Int32">
                    <Value>2147483647</Value>
                </Attribute>
                <Attribute name="long_name" type="String">
                    <Value>Daily population count</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>1</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>Sea Ice ATBD</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>modelResult</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Number of reference surface sections used in each daily grid cell.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>../../grid_x ../../grid_y</Value>
                </Attribute>
                <Attribute name="grid_mapping" type="String">
                    <Value>../../crs: ../../grid_x ../../crs: ../../grid_y</Value>
                </Attribute>
                <Map name="/grid_x"/>
                <Map name="/grid_y"/>
            </Int32>
            <Float32 name="mean_weighted_mss">
                <Dim name="/grid_y"/>
                <Dim name="/grid_x"/>
                <Attribute name="_FillValue" type="Float32">
                    <Value>3.402823466e+38</Value>
                </Attribute>
                <Attribute name="long_name" type="String">
                    <Value>Daily mean MSS</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>meters</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>Sea Ice ATBD</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>modelResult</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Grid-cell mean of the Mean Sea Surface (MSS) values sampled at each reference surface height location used in the daily grid cell. MSS in ATL10 is expressed relative to the WGS-84 reference ellipsoid from a CryoSat-2/DTU13 merged product (https://doi.org/10. 5281/zenodo.4294047) and is in a tide free system. MSS is converted to mean tide when sampled by ATL21 using the geoid_free2mean correction.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>../../grid_x ../../grid_y</Value>
                </Attribute>
                <Attribute name="grid_mapping" type="String">
                    <Value>../../crs: ../../grid_x ../../crs: ../../grid_y</Value>
                </Attribute>
                <Map name="/grid_x"/>
                <Map name="/grid_y"/>
            </Float32>
            <Float32 name="mean_weighted_earth_free2mean">
                <Dim name="/grid_y"/>
                <Dim name="/grid_x"/>
                <Attribute name="_FillValue" type="Float32">
                    <Value>3.402823466e+38</Value>
                </Attribute>
                <Attribute name="long_name" type="String">
                    <Value>Daily mean solid earth tide free-to-mean conversion</Value>
                </Attribute>
                <Attribute name="standard_name" type="String">
                    <Value>solid earth tide free2mean</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>meters</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>Sea Ice ATBD</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>modelResult</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Mean of the solid earth permanent tide correction (height_segment_earth_free2mean in ATL10) sampled at each reference surface height location used in the daily grid cell. Subtract from mean_ssha to remove the solid earth permanent tide.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>../../grid_x ../../grid_y</Value>
                </Attribute>
                <Attribute name="grid_mapping" type="String">
                    <Value>../../crs: ../../grid_x ../../crs: ../../grid_y</Value>
                </Attribute>
                <Map name="/grid_x"/>
                <Map name="/grid_y"/>
            </Float32>
            <Float64 name="delta_time_beg">
                <Dim size="1"/>
                <Attribute name="long_name" type="String">
                    <Value>Elapsed GPS seconds</Value>
                </Attribute>
                <Attribute name="standard_name" type="String">
                    <Value>time</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>seconds since 2018-01-01</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>Derived via Time Tagging</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>modelResult</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Center time of the first reference surface used in this gridded composite in seconds since the ATLAS SDP GPS Epoch.  The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (1980-01-06T00:00:00.000000Z UTC) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed.</Value>
                </Attribute>
            </Float64>
            <Float32 name="mean_weighted_geoid">
                <Dim name="/grid_y"/>
                <Dim name="/grid_x"/>
                <Attribute name="_FillValue" type="Float32">
                    <Value>3.402823466e+38</Value>
                </Attribute>
                <Attribute name="long_name" type="String">
                    <Value>Daily mean geoid</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>meters</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>Sea Ice ATBD</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>modelResult</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Mean of the geoid values (height_segment_geoid in ATL10) sampled at each reference surface height location used in the daily grid cell. Geoid is expressed relative to the WGS-84 reference ellipsoid from EGM2008 and is in a mean-tide system.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>../../grid_x ../../grid_y</Value>
                </Attribute>
                <Attribute name="grid_mapping" type="String">
                    <Value>../../crs: ../../grid_x ../../crs: ../../grid_y</Value>
                </Attribute>
                <Map name="/grid_x"/>
                <Map name="/grid_y"/>
            </Float32>
            <Float32 name="mean_weighted_geoid_free2mean">
                <Dim name="/grid_y"/>
                <Dim name="/grid_x"/>
                <Attribute name="_FillValue" type="Float32">
                    <Value>3.402823466e+38</Value>
                </Attribute>
                <Attribute name="long_name" type="String">
                    <Value>Daily mean geoid free-to-mean conversion</Value>
                </Attribute>
                <Attribute name="standard_name" type="String">
                    <Value>geoid free2mean</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>meters</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>Sea Ice ATBD</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>modelResult</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Mean of the geoid free-to-mean correction (height_segment_geoid_free2mean in ATL10) sampled at each reference surface height location used in the daily grid cell. Subtract from mean_weighted_mss or mean_weighted_geoid to convert to a tide-free system.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>../../grid_x ../../grid_y</Value>
                </Attribute>
                <Attribute name="grid_mapping" type="String">
                    <Value>../../crs: ../../grid_x ../../crs: ../../grid_y</Value>
                </Attribute>
                <Map name="/grid_x"/>
                <Map name="/grid_y"/>
            </Float32>
            <Float32 name="sigma">
                <Dim name="/grid_y"/>
                <Dim name="/grid_x"/>
                <Attribute name="units" type="String">
                    <Value>meters</Value>
                </Attribute>
                <Attribute name="_FillValue" type="Float32">
                    <Value>3.402823466e+38</Value>
                </Attribute>
                <Attribute name="long_name" type="String">
                    <Value>Daily standard deviation</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>Sea Ice ATBD</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>modelResult</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Standard deviation of daily gridded mean sea surface height anomaly, computed following ATBD section 6.3.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>../../grid_x ../../grid_y</Value>
                </Attribute>
                <Attribute name="grid_mapping" type="String">
                    <Value>../../crs: ../../grid_x ../../crs: ../../grid_y</Value>
                </Attribute>
                <Map name="/grid_x"/>
                <Map name="/grid_y"/>
            </Float32>
            <Attribute name="Description" type="String">
                <Value>Gridded daily averages</Value>
            </Attribute>
        </Group>
    </Group>
